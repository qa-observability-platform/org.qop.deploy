# ============================================================
#  QOP – Docker Environment Configuration
#  cp .env.docker.example .env.docker  →  then fill in values
# ============================================================

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=qop_db
POSTGRES_USER=qop_user
POSTGRES_PASSWORD=change-me-strong-password

# ── Security ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production-min-32-chars

# ============================================================
#  SETUP A  —  Local machine  (default, works out of the box)
# ============================================================
QOP_API_URL=http://localhost:4000
QOP_WS_URL=ws://localhost:4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ============================================================
#  SETUP B  —  Remote / production server
#  Replace YOUR_SERVER_IP with your actual IP or domain.
#  No image rebuild needed — just update these URLs and restart.
# ============================================================
# QOP_API_URL=http://YOUR_SERVER_IP:4000
# QOP_WS_URL=ws://YOUR_SERVER_IP:4000
# FRONTEND_URL=http://YOUR_SERVER_IP:3000
# APP_URL=http://YOUR_SERVER_IP:3000

# ── AI Provider Keys (optional) ───────────────────────────
# At least one needed for AI analysis. Groq is free.
# Get Groq key: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# OpenRouter (free tier available)
OPENROUTER_API_KEY=

# Which AI provider to use (groq | openrouter | claude | openai)
PREFERRED_AI_PROVIDER=groq
