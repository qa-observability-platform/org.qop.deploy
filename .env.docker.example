# ============================================================
#  QOP – Docker Environment Configuration
#  1. cp .env.docker.example .env.docker
#  2. Fill in ALL required values below
#  3. docker compose --env-file .env.docker pull
#  4. docker compose --env-file .env.docker up -d
# ============================================================

# ── Database (REQUIRED) ───────────────────────────────────
# Name of the PostgreSQL database
POSTGRES_DB=qop_db

# PostgreSQL login username
POSTGRES_USER=qop_user

# PostgreSQL password — choose a strong one
POSTGRES_PASSWORD=change-me-strong-password

# ── Security (REQUIRED) ───────────────────────────────────
# JWT signing secret — must be at least 32 characters
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32

# ============================================================
#  SETUP A  —  Local machine  (default, works out of the box)
#  Use this if running QOP on your own laptop/desktop.
# ============================================================
QOP_API_URL=http://localhost:4000
QOP_WS_URL=ws://localhost:4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ============================================================
#  SETUP B  —  Remote / on-premise server
#  Comment out SETUP A above and uncomment these lines.
#  Replace YOUR_SERVER_IP with your actual IP or domain.
#  No image rebuild needed — just update these and restart.
# ============================================================
# QOP_API_URL=http://YOUR_SERVER_IP:4000
# QOP_WS_URL=ws://YOUR_SERVER_IP:4000
# FRONTEND_URL=http://YOUR_SERVER_IP:3000
# APP_URL=http://YOUR_SERVER_IP:3000

# ── AI Provider Keys (OPTIONAL) ───────────────────────────
# At least one key needed for AI-powered features.
# Groq is FREE — get a key at https://console.groq.com

# Groq (free, recommended)
GROQ_API_KEY=

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# OpenRouter (free tier available)
OPENROUTER_API_KEY=

# Which AI provider to use (groq | openrouter | claude | openai)
PREFERRED_AI_PROVIDER=groq
