# QOP Docker Environment Configuration
# Copy this file to .env.docker and fill in your values before running docker compose up
#   cp .env.docker.example .env.docker

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production-min-32-chars

# ── URLs ──────────────────────────────────────────────────────────────────────
# If running locally, leave as-is.
# If deploying to a server, set to your server's public IP or domain.
QOP_API_URL=http://localhost:4000
QOP_WS_URL=ws://localhost:4000
FRONTEND_URL=http://localhost:3000
PYTHON_API_URL=http://localhost:8000
APP_URL=http://localhost:3000

# ── AI Provider Keys (optional - needed for AI failure analysis) ──────────────
# At least one is needed for AI features. Groq is free and recommended.
# Get Groq key at: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (paid)
ANTHROPIC_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# OpenRouter (free tier available)
OPENROUTER_API_KEY=

# Which AI provider to use first (groq | openrouter | claude | openai)
PREFERRED_AI_PROVIDER=groq
